# Server
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000
SERVER_URL=http://localhost:3000

# Session
SESSION_SECRET=

# MongoDB (local dev — in production loaded from Google Cloud Secret Manager)
MONGO_URI=mongodb://localhost:27017/tableroom

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Google One-Tap (leave empty to reuse GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET)
GOOGLE_ONE_TAP_CLIENT_ID=
GOOGLE_ONE_TAP_CLIENT_SECRET=

# Email (Nodemailer / Brevo)
MAIL_FROM=
MAIL_PASS=

# Google Cloud (production only)
GOOGLE_CLOUD_PROJECT=

# Bot tuning (optional — defaults apply if not set)
BOT_THINK_MS=
BOT_TURN_BUDGET_MS=
BOT_TURN_DELAY_MIN_MS=
BOT_TURN_DELAY_MAX_MS=
UNO_CALL_WINDOW_MS=

# Debug flags (set to 1 to enable)
UNO_DEBUG_WILDS=
UNO_DEBUG_REBUILD=
UNO_DEBUG_PLAYED=
UNO_DEBUG_PUBLIC=
UNO_DEBUG_REACTIONS=
STARTUP_DEBUG_FILES=
